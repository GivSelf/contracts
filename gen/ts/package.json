{
  "name": "@givself/contracts",
  "version": "0.2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./givself/v1/*": {
      "types": "./dist/givself/v1/*",
      "default": "./dist/givself/v1/*"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "index.ts",
    "givself/**/*.ts"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
